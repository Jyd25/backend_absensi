APP_NAME="Absensi System"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://applab.my.id
FRONTEND_URL=https://frontend-jyd25.vercel.app

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID
APP_TIMEZONE=Asia/Jakarta

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ============================================
# DATABASE — Neon PostgreSQL (tetap pakai Neon)
# ============================================
DB_CONNECTION=pgsql
DB_HOST=ep-xxx-pooler.c-2.us-east-1.aws.neon.tech
DB_PORT=5432
DB_DATABASE=neondb
DB_USERNAME=neondb_owner
DB_PASSWORD=your-neon-password
DB_SSLMODE=require
DB_NEON_ENDPOINT=ep-xxx

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=cloudinary
QUEUE_CONNECTION=database

CACHE_STORE=database

JWT_SECRET=
JWT_ALGO=HS256
JWT_TTL=60
JWT_REFRESH_TTL=10080

REVERB_APP_KEY=your-reverb-key
REVERB_APP_SECRET=your-reverb-secret
REVERB_APP_ID=your-reverb-id
REVERB_HOST=applab.my.id
REVERB_PORT=443
REVERB_SCHEME=https

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_URL=cloudinary://xxx:xxx@xxx
